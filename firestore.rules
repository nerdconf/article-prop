rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: proposals
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, max 200 chars)
    //   - markdownContent: string (required, max 500000 chars)
    //   - coverImage: string (optional, max 800000 chars)
    //   - createdAt: string (required, ISO 8601 date string)
    //   - authorUid: string (required, must match request.auth.uid)
    //
    // Collection: proposals/{proposalId}/comments
    // Document ID: auto-generated
    // Fields:
    //   - text: string (required, max 5000 chars)
    //   - authorName: string (required, max 100 chars)
    //   - createdAt: string (required, ISO 8601 date string)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidProposal(data) {
      return hasOnlyAllowedFields(['title', 'markdownContent', 'coverImage', 'createdAt', 'authorUid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.markdownContent is string && data.markdownContent.size() > 0 && data.markdownContent.size() < 500000 &&
             (!('coverImage' in data) || (data.coverImage is string && data.coverImage.size() < 800000)) &&
             data.createdAt is string &&
             data.authorUid == request.auth.uid;
    }

    function isValidComment(data) {
      return hasOnlyAllowedFields(['text', 'authorName', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 5000 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.createdAt is string;
    }

    match /proposals/{proposalId} {
      // Anyone with the link can read the proposal
      allow read: if true;
      
      // Only authenticated users can create proposals
      allow create: if isAuthenticated() && isValidProposal(request.resource.data);
      
      // Only the author can update or delete
      allow update, delete: if isAuthenticated() && resource.data.authorUid == request.auth.uid && isValidProposal(request.resource.data);
      
      match /comments/{commentId} {
        // Anyone can read comments on a proposal
        allow read: if true;
        
        // Anyone can create a comment (even unauthenticated users like "Futuro Cliente")
        allow create: if isValidComment(request.resource.data);
        
        // No one can update or delete comments for now
        allow update, delete: if false;
      }
    }
  }
}
